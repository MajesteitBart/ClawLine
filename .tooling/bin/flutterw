#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/../.." && pwd)"
VERSION_FILE="$ROOT_DIR/.tooling/flutter.version"
CHANNEL="stable"
VERSION="$(tr -d '[:space:]' < "$VERSION_FILE")"
SDK_PARENT="$ROOT_DIR/.tooling/sdk"
SDK_ROOT="$SDK_PARENT/flutter"
DOWNLOAD_DIR="$ROOT_DIR/.tooling/downloads"
ARCHIVE_NAME="flutter_linux_${VERSION}-${CHANNEL}.tar.xz"
ARCHIVE_PATH="$DOWNLOAD_DIR/$ARCHIVE_NAME"
BASE_URL="https://storage.googleapis.com/flutter_infra_release/releases/${CHANNEL}/linux"
DOWNLOAD_URL="${BASE_URL}/${ARCHIVE_NAME}"

bootstrap() {
  mkdir -p "$SDK_PARENT" "$DOWNLOAD_DIR"

  if [[ -f "$ARCHIVE_PATH" ]] && ! tar -tJf "$ARCHIVE_PATH" >/dev/null 2>&1; then
    echo "Discarding corrupt Flutter archive..."
    rm -f "$ARCHIVE_PATH"
  fi

  if [[ ! -f "$ARCHIVE_PATH" ]]; then
    echo "Downloading Flutter ${VERSION} (${CHANNEL})..."
    tmp_archive="$(mktemp "$DOWNLOAD_DIR/${ARCHIVE_NAME}.part.XXXXXX")"
    trap 'rm -f "$tmp_archive"' EXIT
    curl --fail --location --retry 3 "$DOWNLOAD_URL" --output "$tmp_archive"
    tar -tJf "$tmp_archive" >/dev/null
    mv "$tmp_archive" "$ARCHIVE_PATH"
    trap - EXIT
  fi

  rm -rf "$SDK_ROOT"
  tmp_dir="$(mktemp -d "$SDK_PARENT/.extract.XXXXXX")"
  trap 'rm -rf "$tmp_dir"' EXIT

  echo "Extracting Flutter SDK..."
  tar -xJf "$ARCHIVE_PATH" -C "$tmp_dir"
  mv "$tmp_dir/flutter" "$SDK_ROOT"
  trap - EXIT
  rm -rf "$tmp_dir"
}

if [[ ! -x "$SDK_ROOT/bin/flutter" ]]; then
  bootstrap
fi

exec "$SDK_ROOT/bin/flutter" "$@"
