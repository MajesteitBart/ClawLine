#!/usr/bin/env python3
"""Minimal unzip shim for Flutter SDK bootstrap in constrained environments."""

from __future__ import annotations

import argparse
import shutil
import sys
import zipfile
from pathlib import Path


def parse_args() -> argparse.Namespace:
    parser = argparse.ArgumentParser(add_help=False)
    parser.add_argument("-q", action="store_true")
    parser.add_argument("-o", action="store_true")
    parser.add_argument("-d", dest="output_dir", default=".")
    parser.add_argument("archive")
    parser.add_argument("members", nargs="*")
    return parser.parse_args()


def main() -> int:
    args = parse_args()
    archive_path = Path(args.archive)
    destination = Path(args.output_dir)
    destination.mkdir(parents=True, exist_ok=True)

    with zipfile.ZipFile(archive_path) as archive:
        members = args.members or archive.namelist()
        for member in members:
            target_path = destination / member
            if target_path.exists() and args.o:
                if target_path.is_dir():
                    shutil.rmtree(target_path)
                else:
                    target_path.unlink()
            archive.extract(member, destination)

    return 0


if __name__ == "__main__":
    sys.exit(main())
